      <span class="amfa-credits-copy">Copyright &copy; 2026 Aegis MFA - Lazaros Chalkidis</span>
      <button type="button" id="amfaCreditsOkBtn" class="amfa-credits-ok-btn">OK</button>
    </div>
  </div>
</div>

</div>

<script>
(function () {
    'use strict';

    // collapsible sections
    document.querySelectorAll('.amfa-sec-hd').forEach(function (hd) {
        hd.addEventListener('click', function () {
            hd.parentElement.classList.toggle('closed');
        });
    });

    // credits modal
    var modal = document.getElementById('amfaCreditsModal');
    var cLink = document.getElementById('amfaCreditsLink');
    var okBtn = document.getElementById('amfaCreditsOkBtn');
    if (cLink && modal) cLink.addEventListener('click', function (e) { e.preventDefault(); modal.style.display = 'flex'; });
    if (okBtn && modal) okBtn.addEventListener('click', function () { modal.style.display = 'none'; });
    if (modal) {
        modal.addEventListener('click', function (e) { if (e.target === modal) modal.style.display = 'none'; });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') modal.style.display = 'none'; });
    }

    // confirm dialog. Buttons opt in with data-amfa-confirm and describe
    // themselves through data-c-* attributes; a confirmed click re-fires
    // the same button so the native submit keeps its name/value pair.
    var cOvl    = document.getElementById('amfaConfirmModal');
    var cBox    = cOvl ? cOvl.querySelector('.amfa-confirm-box') : null;
    var cTitle  = document.getElementById('amfaConfirmTitle');
    var cMsg    = document.getElementById('amfaConfirmMsg');
    var cIcon   = document.getElementById('amfaConfirmIconEl');
    var cOk     = document.getElementById('amfaConfirmOk');
    var cCancel = document.getElementById('amfaConfirmCancel');
    var uField  = document.getElementById('amfaUserField');
    var armed   = null;

    function cClose() { if (cOvl) cOvl.classList.remove('open'); }

    document.querySelectorAll('button[data-user], button[data-amfa-confirm]').forEach(function (btn) {
        btn.addEventListener('click', function (e) {
            // per-row target: one shared hidden field, set at click time
            if (uField && btn.hasAttribute('data-user')) uField.value = btn.getAttribute('data-user');
            if (!btn.hasAttribute('data-amfa-confirm') || !cOvl) return;
            if (armed === btn) { armed = null; return; }
            e.preventDefault();
            var danger = btn.hasAttribute('data-c-danger');
            cBox.classList.toggle('danger', danger);
            cTitle.textContent = btn.getAttribute('data-c-title') || 'Are you sure?';
            cMsg.textContent   = btn.getAttribute('data-c-msg') || '';
            cIcon.className    = 'fa ' + (btn.getAttribute('data-c-icon') || 'fa-question');
            cOk.textContent    = btn.getAttribute('data-c-ok') || 'OK';
            cOk.onclick = function () { cClose(); armed = btn; btn.click(); };
            cOvl.classList.add('open');
            // a stray Enter must not fire a destructive action
            (danger ? cCancel : cOk).focus();
        });
    });
    if (cCancel) cCancel.addEventListener('click', cClose);
    if (cOvl) {
        cOvl.addEventListener('click', function (e) { if (e.target === cOvl) cClose(); });
        document.addEventListener('keydown', function (e) { if (e.key === 'Escape') cClose(); });
    }

    // trusted LAN: one-click add of the admin's own address
    var myIp  = document.getElementById('amfaMyIpAdd');
    var lanTa = document.getElementById('amfaTrustLan');
    if (myIp && lanTa) myIp.addEventListener('click', function (e) {
        e.preventDefault();
        var ip = myIp.textContent.trim();
        var have = lanTa.value.split(/\r?\n/).map(function (s) { return s.trim(); });
        if (have.indexOf(ip) === -1) {
            lanTa.value = lanTa.value.replace(/\s+$/, '');
            lanTa.value += (lanTa.value === '' ? '' : '\n') + ip;
        }
        lanTa.focus();
    });
})();
</script>

