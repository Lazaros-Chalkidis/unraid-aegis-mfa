$amfaEsc = fn($s) => htmlspecialchars((string)$s, ENT_QUOTES, 'UTF-8');
$amfaNotice = ''; $amfaNoticeKind = 'ok'; $amfaNewCodes = null; $amfaBypassUrl = null;

// POST actions, Unraid's own csrf_token is validated upstream
if ($_SERVER['REQUEST_METHOD'] === 'POST' && isset($_POST['amfa_action'])) {
    switch ($_POST['amfa_action']) {

        case 'toggle':
            $on = ($_POST['enabled'] ?? '') === '1';
            aegis_mfa_set_enabled($on);
            if ($on && (int)aegis_mfa_config(true)['enforce_after'] === 0) {
                aegis_mfa_start_dry_run(24);   // first enable begins with dry-run
            }
            $r = aegis_mfa_reconcile_patches();
            if ($on && ($r['ok'] ?? false)) {
                aegis_mfa_sync_users();
            }
            if ($on && !($r['ok'] ?? false)) {
                aegis_mfa_set_enabled(false);
                aegis_mfa_reconcile_patches();
                $amfaNotice = 'Could not enable: the Unraid login files are not in the expected '
                            . 'shape (' . ($r['reason'] ?? 'unknown') . '). Nothing was changed '
                            . 'and MFA stays off. This usually means Unraid restructured these files, '
                            . 'or another plugin has patched them.';
                $amfaNoticeKind = 'err';
            } else {
                $amfaNotice = $on ? 'MFA enabled. A dry run is running, see the banner below to enforce now.'
                                  : 'MFA disabled, login patches removed.';
            }
            break;

        case 'enforce_now':
            aegis_mfa_enforce_now();
            $amfaNotice = 'MFA is now enforcing.';
            break;

        case 'save_lan':
            $lines = preg_split('/[\s,]+/', (string)($_POST['trust_lan'] ?? ''));
            $r = aegis_mfa_set_trust_lan($lines);
            $amfaNotice = count($r['rejected'])
                ? 'Saved. Rejected invalid entries: ' . implode(', ', $r['rejected'])
                : 'Trusted LAN saved.';
            if (count($r['rejected'])) $amfaNoticeKind = 'warn';
            break;

        case 'save_grace':
            aegis_mfa_set_grace_days((int)($_POST['grace_days'] ?? 7));
            $amfaNotice = 'Grace period saved.';
            break;

        case 'regen_codes':
            $amfaNewCodes = aegis_mfa_regenerate_backup_codes((string)($_POST['user'] ?? ''));
            $amfaNotice = $amfaNewCodes === null
                ? 'User is not enrolled.' : 'New backup codes generated, shown once below.';
            if ($amfaNewCodes === null) $amfaNoticeKind = 'err';
            break;

        case 'reset_user':
            aegis_mfa_reset_user((string)($_POST['user'] ?? ''), true);
            $amfaNotice = 'User reset to pending, they must re-enrol.';
            break;

        case 'bypass':
            $u = (string)($_POST['user'] ?? '');
            $tok = aegis_mfa_create_bypass_token($u, 86400);
            if ($tok !== null) {
                $scheme = (!empty($_SERVER['HTTPS']) && $_SERVER['HTTPS'] !== 'off') ? 'https' : 'http';
                $amfaBypassUrl = $scheme . '://' . ($_SERVER['HTTP_HOST'] ?? 'unraid')
                               . '/plugins/aegis.mfa/include/setup.php?user='
                               . rawurlencode($u) . '&token=' . $tok;
                $amfaNotice = 'One-time setup link created (valid 24h), shown once below.';
            } else {
                $amfaNotice = 'Could not create the link.'; $amfaNoticeKind = 'err';
            }
            break;

        case 'sync_users':
            $r = aegis_mfa_sync_users();
            if (($r['skipped'] ?? '') === 'no_live_users') {
                $amfaNotice = 'Sync failed: the Unraid account list could not be read '
                            . '(getent returned nothing usable). Run "aegis-mfa users" '
                            . 'in a terminal to see what the enumeration finds.';
                $amfaNoticeKind = 'err';
            } else {
                $amfaNotice = 'Synced. Accounts seen: ' . (int)($r['live'] ?? 0)
                            . '. Added: ' . count($r['added'])
                            . ', removed: ' . count($r['removed']) . '.';
                if (($r['skipped'] ?? '') === 'no_root_in_list') {
                    $amfaNotice .= ' Add-only run: root was missing from the snapshot, '
                                 . 'so nothing was removed.';
                    $amfaNoticeKind = 'warn';
                }
            }
            break;
    }
}

