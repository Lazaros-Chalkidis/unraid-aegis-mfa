$amfaPatch = aegis_mfa_patch_state();
$amfaValidated = aegis_mfa_version_validated();
$amfaUnraid = @trim(str_replace('"', '', explode('=', @file_get_contents('/etc/unraid-version') ?: '')[1] ?? ''));

